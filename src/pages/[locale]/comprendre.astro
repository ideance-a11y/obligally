---
import Layout from '@layouts/Layout.astro'
import Hero from '@components/Hero.astro'

import { initI18n, getLangFromUrl } from '@/assets/i18n/i18n.ts'

const lang = getLangFromUrl(Astro.url)
const t = await initI18n(lang)

export async function getStaticPaths() {
  return [/*{ params: { locale: 'en' } },*/ { params: { locale: 'fr' } }]
}

import PageContentFr from '@/components/page-content/comprendre.fr.astro'
import PageContentEn from '@/components/page-content/comprendre.en.astro'

const PageContent = lang === 'fr' ? PageContentFr : PageContentEn
---

<Layout
  lang={lang}
  pageTitle={t('nave.comprendre')}
  metaDescription={t('comprendre.metadescription')}
>
  <Hero
    slot="hero"
    lang={lang}
    heading={t('nav.comprendre')}
    subheading={t('comprendre.subheading')}
  >
    <span
      slot="icon"
      class="ice-icon icon-info"
      aria-hidden="true"
    ></span>
  </Hero>

  <div class="ice-section with-typo-styles">
    <PageContent />
  </div>
</Layout>
